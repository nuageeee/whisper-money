{
    "hooks": {
        "after:bump": "node scripts/enrich-changelog.js && git add CHANGELOG.md"
    },
    "git": {
        "commitMessage": "chore: release v${version}",
        "tagName": "v${version}",
        "requireBranch": false,
        "requireCleanWorkingDir": true,
        "push": true
    },
    "github": {
        "release": true,
        "releaseName": "v${version}"
    },
    "npm": {
        "publish": false
    },
    "plugins": {
        "@release-it/conventional-changelog": {
            "preset": "angular",
            "infile": "CHANGELOG.md"
        }
    }
}
